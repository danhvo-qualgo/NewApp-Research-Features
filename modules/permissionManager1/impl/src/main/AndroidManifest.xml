<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        Required on Android 11+ (API 30+) to enumerate installed packages and
        read their declared permissions via PackageManager.getInstalledPackages().
    -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <application>
        <activity
            android:name="com.safeNest.demo.features.permissionManager1.impl.presentation.PermissionManagerActivity"
            android:exported="false"
            android:label="@string/title_activity_permission_manager" />
    </application>

</manifest>
