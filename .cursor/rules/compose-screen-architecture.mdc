## Complete Example

```kotlin
// ✅ GOOD - Following all patterns
@Composable
fun SignInScreen(
    viewModel: SignInViewModel = hiltViewModel()
) {
    val uiState = viewModel.uiState.collectAsState()

    Scaffold { paddingValues ->
        SignInContent(
            email = uiState.value.email,
            onEmailChange = viewModel::onEmailChange,
            onAppleClick = viewModel::signInApple,
            onGoogleClick = viewModel::signInGoogle,
            onNextClick = viewModel::signInEmail
        )
    }
}

@Composable
private fun SignInContent(
    email: String,
    onEmailChange: (String) -> Unit,
    onAppleClick: () -> Unit,
    onGoogleClick: () -> Unit,
    onNextClick: () -> Unit
) {
    Column {
        // Sections based on actual screen structure
        SignInHeader()
        SocialSignInButtons(onAppleClick, onGoogleClick)
        EmailSignInSection(email, onEmailChange, onNextClick)
        SignInFooter()
    }
}
```